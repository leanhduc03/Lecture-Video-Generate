# Database Configuration
DATABASE_URL=mysql+mysqlconnector://root:your_password@db:3306/lecvid_gen
MYSQL_ROOT_PASSWORD=your_mysql_password
MYSQL_DATABASE=lecvid_gen

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAILS_FROM_EMAIL=your_email@gmail.com
EMAILS_FROM_NAME=LecVidGen Support

# JWT Configuration
SECRET_KEY=your-super-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=11520
VERIFICATION_CODE_EXPIRE_MINUTES=30

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Gemini AI Configuration
GEMINI_API_KEY=your_gemini_api_key
GEMINI_REWRITE_API_KEY=your_rewrite_api_key
GEMINI_MODEL_NAME=models/gemini-2.5-flash

# External API URLs
DEEPFAKE_API_URL=your_deepfake_api_url
TTS_API_URL=your_tts_api_url
FAKELIP_API_URL=your_fakelip_api_url